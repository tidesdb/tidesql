call mtr.add_suppression("\\[TIDESDB\\].*TDB_ERR_CONFLICT");
CREATE TABLE c (
id  INT PRIMARY KEY,
v   INT NOT NULL
) ENGINE=TidesDB;
INSERT INTO c VALUES (1, 10), (2, 20);
connect  a, localhost, root,,;
connect  b, localhost, root,,;
connection a;
BEGIN;
UPDATE c SET v = v + 1 WHERE id = 1;
connection b;
BEGIN;
UPDATE c SET v = v + 1 WHERE id = 2;
connection a;
UPDATE c SET v = v + 1 WHERE id = 2;
connection b;
UPDATE c SET v = v + 1 WHERE id = 1;
ERROR 40001: Deadlock found when trying to get lock; try restarting transaction
ROLLBACK;
connection a;
COMMIT;
connection default;
# Row 1 incremented by T1 only (T2 aborted); row 2 incremented by T1 only.
SELECT * FROM c ORDER BY id;
id	v
1	11
2	21
disconnect a;
disconnect b;
connection default;
DROP TABLE c;
# Done.
